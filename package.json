{
  "name": "meduza-server-store",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "turbo test:unit",
    "test:integration": "npm run test:integration:modules --workspace=@dtc/backend && npm run test:integration:http --workspace=@dtc/backend",
    "test:smoke": "npm run test:smoke --workspace=@dtc/storefront",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "2.16.0",
    "eslint": "^9.39.4",
    "jiti": "^2.7.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ]
}
